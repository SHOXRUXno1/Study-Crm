# ============================================================
# Root .env example for docker compose (monorepo)
# Copy to .env and adjust before `docker compose up`.
# Production: replace ALL secrets and set ENV=production.
# ============================================================

# ---------- Postgres ----------
POSTGRES_USER=study
POSTGRES_PASSWORD=study_local_dev
POSTGRES_DB=study

# ---------- Backend (FastAPI) ----------
# Use ENV=production only when SECRET_KEY/ADMIN_PASSWORD/DATABASE_URL are real.
ENV=development
SECRET_KEY=please-change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin123

# CORS — comma-separated list of allowed origins.
# In compose, the frontend talks to the backend through nginx on the same origin
# (http://localhost:8080), so that origin is enough for local dev.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Receipts / uploads
UPLOAD_DIR=/app/uploads
RECEIPT_MAX_SIZE_MB=10
RECEIPT_MAX_FILES_PER_PAYMENT=5
